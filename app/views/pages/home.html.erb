<div class="hero d-flex align-items-center">
  <div class="container text-center">
    <h1 class="hero-title">Wagi - Your AI Coding Assistant</h1>
    <p class="hero-subtitle">Stuck on a challenge? Get instant, personalized guidance from an AI that understands your code.</p>
    <div class="d-flex justify-content-center gap-3 mt-4">
      <%= link_to "Get Started", new_user_registration_path, class: "btn btn-primary btn-lg" %>
      <% if user_signed_in? == false %>
        <%= link_to "Sign In", new_user_session_path, class: "btn btn-outline-light btn-lg" %>
      <% end %>
    </div>
  </div>
</div>

<div class="container py-5">
  <div class="row g-4 text-center">
    <div class="col-md-4">
      <div class="feature-card p-4">
        <i class="fa-solid fa-robot fa-2x mb-3 text-primary"></i>
        <h5>AI-Powered Help</h5>
        <p class="text-muted">Ask anything about your challenge and get clear, step-by-step explanations.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="feature-card p-4">
        <i class="fa-solid fa-comments fa-2x mb-3 text-primary"></i>
        <h5>Conversation History</h5>
        <p class="text-muted">Pick up where you left off — all your chats are saved per challenge.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="feature-card p-4">
        <i class="fa-solid fa-graduation-cap fa-2x mb-3 text-primary"></i>
        <h5>Learn by Doing</h5>
        <p class="text-muted">The AI guides you toward the solution without just giving you the answer.</p>
      </div>
    </div>
  </div>
</div>
