<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="d-flex justify-content-between align-items-start mb-4">
        <%= link_to challenges_path, class: "btn btn-sm btn-outline-secondary" do %>
          <i class="fa-solid fa-arrow-left me-1"></i> Back
        <% end %>
        <% if @challenge.user == current_user %>
          <div class="d-flex gap-2">
            <%= link_to "Edit", edit_challenge_path(@challenge), class: "btn btn-sm btn-outline-primary" %>
            <%= link_to "Delete", @challenge, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" %>
          </div>
        <% end %>
      </div>

      <div class="challenge-show-card p-5">
        <span class="challenge-module"><%= @challenge.module %></span>
        <h1 class="fw-bold mt-2 mb-4"><%= @challenge.name %></h1>
        <div class="challenge-content">
          <%= simple_format(@challenge.content) %>
        </div>
      </div>

      <div class="text-center mt-4">
        <%= link_to "Chat with Wagi about this challenge", "#", class: "btn btn-primary btn-lg" %>
      </div>

    </div>
  </div>
</div>
