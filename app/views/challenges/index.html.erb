<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Challenges</h2>
    <%= link_to "New Challenge", new_challenge_path, class: "btn btn-primary" %>
  </div>

  <div class="row g-4">
    <% @challenges.each do |challenge| %>
      <div class="col-md-4">
        <div class="challenge-card p-4">
          <span class="challenge-module"><%= challenge.module %></span>
          <h5 class="mt-2 fw-bold"><%= challenge.name %></h5>
          <p class="text-muted"><%= truncate(challenge.content, length: 100) %></p>
          <%= link_to "View Challenge", challenge, class: "btn btn-outline-primary btn-sm mt-2" %>
        </div>
      </div>
    <% end %>
  </div>

  <% if @challenges.empty? %>
    <div class="text-center py-5 text-muted">
      <i class="fa-solid fa-circle-question fa-3x mb-3"></i>
      <p>No challenges yet. <%= link_to "Create the first one!", new_challenge_path %></p>
    </div>
  <% end %>
</div>
